# Required for every production deployment
SESSION_SECRET=replace-with-a-long-random-string
DATABASE_URL=data/app.db

# Required for the first production boot on an empty database
BOOTSTRAP_LEAD_EMAIL=
BOOTSTRAP_LEAD_NAME=
BOOTSTRAP_LEAD_PASSWORD=

# Local development defaults
SEED_USER_PASSWORD=changeme123!

# Leave disabled in normal production operation
# ALLOW_SEED_DATA=true
